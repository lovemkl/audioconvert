{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AudioConvert",
  "version": "1.0.0",
  "identifier": "com.audioconvert.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AudioConvert",
        "width": 900,
        "height": 620,
        "minWidth": 680,
        "minHeight": 480,
        "resizable": true,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/ffmpeg",
      "bin/ffprobe"
    ],
    "resources": [],
    "copyright": "© 2026 AudioConvert Contributors",
    "category": "Utility",
    "shortDescription": "Local audio format converter",
    "longDescription": "A cross-platform desktop audio format converter supporting 30+ formats. Works completely offline.",
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "languages": ["SimpChinese", "English"]
      }
    }
  }
}
