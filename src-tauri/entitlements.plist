<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Allow the app to run with hardened runtime (required for Gatekeeper) -->
  <key>com.apple.security.cs.allow-jit</key>
  <false/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <false/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Allow reading/writing user-selected files via open/save dialog -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
  <!-- Allow reading Downloads folder for importing audio files -->
  <key>com.apple.security.files.downloads.read-write</key>
  <true/>
  <!-- Allow spawning child processes (ffmpeg sidecar) -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <false/>
</dict>
</plist>
